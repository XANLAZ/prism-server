# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf

# Docker files should use LF
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yaml text eol=lf

# Go files
*.go text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Scripts
*.py text eol=lf
*.pl text eol=lf
